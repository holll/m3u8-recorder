# m3u8-recorder 示例配置
# 复制为 .env 后按需修改

# 录像文件根目录
DOWNLOAD_PATH=./downloads

# ffmpeg segment 切片秒数
SPLIT_SECONDS=600

# Web UI 监听端口
WEBUI_PORT=8080

# 请求时使用的 User-Agent
REQUEST_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# 定时录制窗口（可选）
# 留空表示不启用定时录制；两项都填写才会启用
# 示例：08:00 到次日 02:00
RECORD_SCHEDULE_START=
RECORD_SCHEDULE_END=
